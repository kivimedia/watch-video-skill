# CutSense Environment Variables

# AI Providers (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=...

# Optional: HuggingFace token for WhisperX speaker diarization
HF_TOKEN=hf_...

# Optional: Custom jobs directory (default: ~/.cutsense/jobs/)
CUTSENSE_JOBS_DIR=

# Optional: Default AI provider (anthropic|openai|gemini)
CUTSENSE_DEFAULT_PROVIDER=anthropic

# Optional: Default model per provider
CUTSENSE_DEFAULT_MODEL=
